# Copy to .env and fill in. The server loads .env from the ai-compendium directory.

# Public URL used in password-reset emails (no trailing slash)
PUBLIC_BASE_URL=http://localhost:3000

# --- SMTP (password reset emails) ---
# Default: Mailpit on localhost (no auth). Run: docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_SECURE=false

# Gmail (use a Google Account App Password, not your normal password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM="AI Compendium <you@gmail.com>"

# Optional: log SMTP host/port on startup (no secrets)
# SMTP_LOG_CONFIG=true

# Optional: include detailed SMTP errors in the HTTP 503 JSON (use only for debugging)
# SMTP_DEBUG=true

# --- OpenAI (tag suggestions when adding a resource) ---
# OPENAI_API_KEY=sk-...
# Optional model override (default: gpt-4o-mini)
# OPENAI_SUGGEST_MODEL=gpt-4o-mini

# --- Magic word page: triple-click the middle dot in “MSAI · CAT” on the home page ---
# Set a non-empty value in your real .env (same key), then restart the server.
MAGIC_PAGE_PASSWORD=
# Public URL path for the CRT page (default /magic-word.html). Use an obscure path to avoid an obvious URL;
# home page opens it via /api/magic-page/redirect (path is not in app.js). The browser still shows the final path.
# MAGIC_PAGE_PATH=/g/7f2a9c1e4b8d
# Optional HMAC secret for cookie (defaults to MAGIC_PAGE_PASSWORD)
# MAGIC_PAGE_COOKIE_SECRET=
# HTTPS production: cookie Secure flag
# MAGIC_PAGE_COOKIE_SECURE=true
# Unlock endpoint: max 12 wrong passwords / 15 min per IP (429 + Retry-After)
